---
import Layout from '../layouts/Layout.astro';
const designers = [
  { name: 'The UX Lead', desc: 'Overthinks every angle and analyzes the flow before pulling the trigger.' },
  { name: 'The Brand Designer', desc: 'Rallies the team with a megaphone and calls a kickoff every round.' },
  { name: 'The Motion Designer', desc: 'Steady hands, tidy keyframes and a reliably accurate shot.' },
  { name: 'The Product Designer', desc: 'Cool under pressure and clinical with every shot — right on target.' },
  { name: 'The Illustrator', desc: 'Calibrated aura and a sharp eye: only fires when the palette feels right.' },
];
const developers = [
  { name: 'The Backend Dev', desc: 'Long-haul focus and nerves of steel — brakes for no one.' },
  { name: 'The Frontend Dev', desc: 'Flashy shades and a sponsored aim: ships, posts, repeats.' },
  { name: 'The DevOps Engineer', desc: 'Pipeline on the back and a pipeline in the fight — deploys in double time.' },
  { name: 'The QA Engineer', desc: 'Sees every edge case and somehow always knows where you are.' },
  { name: 'The Tech Lead', desc: 'Headset on, 47 frameworks ready — already won before standup, in theory.' },
];
---
<Layout title="Characters — Umain Arena">
  <h1>CHARACTERS</h1>
  <p>Ten original, fictional archetypes. Each has its own silhouette, accessories and style, modeled in procedural low-poly.</p>

  <h2 style="color:#ff8080">DESIGNERS</h2>
  <ul>{designers.map(c => <li style="margin:8px 0"><strong style="color:#f2ead8">{c.name}</strong> — {c.desc}</li>)}</ul>

  <h2 style="color:#9dff9d">DEVELOPERS</h2>
  <ul>{developers.map(c => <li style="margin:8px 0"><strong style="color:#f2ead8">{c.name}</strong> — {c.desc}</li>)}</ul>

  <p style="margin-top:22px">Pick yours in the game: <a href="/">▶ PLAY</a></p>
</Layout>
